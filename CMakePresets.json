{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "template",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_FRONTEND_API": true,
        "ENABLE_QT": true
      }
    },
    {
      "name": "windows-clangcl-x64",
      "displayName": "Windows x64 (VS 2026 + ClangCL)",
      "description": "Build for Windows x64 with Visual Studio 2026, ClangCL, and the official OBS plugin template dependency bootstrap",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "toolset": "ClangCL",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "windows-clangcl-vs2022-x64",
      "displayName": "Windows x64 (VS 2022 + ClangCL)",
      "description": "Build for Windows x64 with Visual Studio 2022, ClangCL, and the official OBS plugin template dependency bootstrap",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_vs2022_x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "toolset": "ClangCL",
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "ubuntu-x86_64",
      "displayName": "Ubuntu x86_64",
      "description": "Build for Ubuntu x86_64",
      "inherits": ["template"],
      "binaryDir": "${sourceDir}/build_x86_64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "warnings": {
        "dev": true,
        "deprecated": true
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_INSTALL_LIBDIR": "lib/CMAKE_SYSTEM_PROCESSOR-linux-gnu"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-clangcl-x64",
      "configurePreset": "windows-clangcl-x64",
      "displayName": "Windows x64 (VS 2026 + ClangCL)",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "windows-clangcl-vs2022-x64",
      "configurePreset": "windows-clangcl-vs2022-x64",
      "displayName": "Windows x64 (VS 2022 + ClangCL)",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "ubuntu-x86_64",
      "configurePreset": "ubuntu-x86_64",
      "displayName": "Ubuntu x86_64",
      "configuration": "RelWithDebInfo"
    }
  ]
}
